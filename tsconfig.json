{
    "compilerOptions": {
        "target": "es2017",
        "module": "commonjs",
        "strict": true,
        "declaration": true,
        "outDir": "lib",
        "removeComments": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "sourceMap": true,
        "baseUrl": "./",
        "paths": {
            "*": ["node_modules/*", "src/types/*"]
        }
    },
    "exclude": ["tests", "lib", "node_modules"],
    "include": ["src/**/*"]
}
